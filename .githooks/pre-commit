#!/bin/sh
# pre-commit secret guard — keep secrets/credentials out of your ~/.claude config repo.
# Dependency-free (pure grep). If you hit a genuine false positive: git commit --no-verify (use with care).
#
# กัน secret/credential เข้า repo: บล็อกชื่อไฟล์อ่อนไหว + สแกนเนื้อ staged หา pattern key/token
# ไม่พึ่ง dependency (grep ล้วน). false positive จริง ๆ ค่อย --no-verify (ระวัง)

staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

# 1) hard-block sensitive filenames (in case of an accidental `git add -f`)
#    บล็อกชื่อไฟล์อ่อนไหวที่เผลอ add เข้ามา
if printf '%s\n' "$staged" | grep -Eq '(^|/)\.credentials\.json$|\.pem$|\.key$|(^|/)settings\.local\.json$|-private\.md$'; then
  echo "✗ pre-commit BLOCK: staged a sensitive file (.credentials.json / *.pem / *.key / settings.local.json / *-private.md)"
  exit 1
fi

# 2) scan staged content for secret-like patterns
#    สแกนเนื้อ staged หา pattern ของ secret (key/token/private-key ฯลฯ)
if git diff --cached -U0 | grep -nE \
   'sk-ant-[A-Za-z0-9_-]{16,}|sk-[A-Za-z0-9]{20,}|ghp_[A-Za-z0-9]{30,}|github_pat_[A-Za-z0-9_]{30,}|gho_[A-Za-z0-9]{30,}|AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----|xox[baprs]-[A-Za-z0-9-]{10,}|"(access|refresh|client)_(token|secret)"[[:space:]]*:[[:space:]]*"[^"]+"'; then
  echo "✗ pre-commit BLOCK: secret-like content in staged diff (see lines above). Fix and re-stage, or --no-verify if you are sure it is a false positive."
  exit 1
fi

exit 0
